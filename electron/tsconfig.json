{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "outDir": "../.electron-out",
    "rootDir": ".",
    "sourceMap": true,
    "types": ["node"],
    "paths": {
      "@/*": ["../*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}

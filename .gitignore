# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
# /build is electron-builder's buildResources dir — ignore its contents
# but keep the committed app-icon resources so packaged builds use them.
/build/*
!/build/icon.icns
!/build/icon-source.png

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# runtime data
/data
/data-electron-dev

# electron
/.electron-out
/dist-electron
/electron-build

# typescript
*.tsbuildinfo
next-env.d.ts
